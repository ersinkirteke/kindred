// Prisma schema for Kindred backend
// Database: PostgreSQL 15+
// ORM: Prisma 7.x

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [postgis(schema: "public")]
}

// Enums
enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ImageStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum Platform {
  IOS
  ANDROID
}

enum CuisineType {
  ITALIAN
  MEXICAN
  CHINESE
  JAPANESE
  SICHUAN
  CANTONESE
  INDIAN
  THAI
  KOREAN
  VIETNAMESE
  MEDITERRANEAN
  FRENCH
  SPANISH
  GREEK
  MIDDLE_EASTERN
  LEBANESE
  TURKISH
  MOROCCAN
  ETHIOPIAN
  AMERICAN
  SOUTHERN
  TEX_MEX
  BRAZILIAN
  PERUVIAN
  CARIBBEAN
  BRITISH
  GERMAN
  FUSION
  OTHER
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  DESSERT
  APPETIZER
  DRINK
}

enum VoiceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  DELETED
}

// User model - authenticated via Clerk
model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  bookmarks     Bookmark[]
  deviceTokens  DeviceToken[]
  voiceProfiles VoiceProfile[]
  subscription  Subscription?
  pantryItems   PantryItem[]
  scanJobs      ScanJob[]

  @@index([email])
}

// Recipe model - scraped from X/Instagram or Spoonacular
model Recipe {
  id          String          @id @default(cuid())
  name        String
  description String?

  // Time and servings
  prepTime    Int             // minutes
  cookTime    Int?            // minutes
  servings    Int?

  // Nutritional info (AI-estimated via Gemini)
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?

  // Difficulty and tags
  difficulty  DifficultyLevel @default(BEGINNER)
  dietaryTags String[]        // ['vegan', 'gluten-free', 'keto', 'halal', etc.]

  // Cuisine and meal classification (AI-tagged during scraping)
  cuisineType CuisineType     @default(OTHER)
  mealType    MealType        @default(DINNER)

  // AI-generated hero image
  imageUrl    String?
  imageStatus ImageStatus     @default(PENDING)

  // Scraping metadata
  scrapedFrom String          // 'x' | 'instagram' | 'curated' | 'spoonacular'
  sourceId    String?         @unique // for deduplication
  scrapedAt   DateTime        @default(now())
  location    String?         // city-level granularity (nullable for Spoonacular recipes)

  // Geospatial data (geocoded from location field)
  latitude    Float?
  longitude   Float?

  // Spoonacular-specific fields
  spoonacularId   Int?    @unique // Spoonacular recipe ID
  popularityScore Int?    @default(0) // Maps to aggregateLikes
  sourceUrl       String? // Original recipe source URL
  sourceName      String? // Source website name
  plainText       String? // Concatenated ingredients+steps for Phase 24 AVSpeech

  // Engagement metrics (backward compat until Phase 26)
  engagementLoves     Int     @default(0)
  engagementBookmarks Int     @default(0)
  engagementViews     Int     @default(0)
  isViral             Boolean @default(false)
  velocityScore       Float   @default(0) // cached engagement velocity

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ingredients Ingredient[]
  steps       RecipeStep[]
  bookmarkedBy Bookmark[]

  @@index([location])
  @@index([scrapedAt])
  @@index([isViral])
  @@index([scrapedFrom])
  @@index([cuisineType])
  @@index([mealType])
  @@index([velocityScore])
  @@index([spoonacularId])
  @@index([popularityScore])
}

// Ingredient model - normalized structure
model Ingredient {
  id         String @id @default(cuid())
  recipeId   String
  recipe     Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Normalized ingredient data
  name           String  // normalized (e.g., "chicken breast")
  normalizedName String? // link to IngredientCatalog for recipe matching
  quantity       String  // "2"
  unit           String  // "cups"
  orderIndex     Int     // display order

  @@index([recipeId])
  @@index([normalizedName])
}

// RecipeStep model - AI-parsed structured steps
model RecipeStep {
  id           String  @id @default(cuid())
  recipeId     String
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  orderIndex   Int     // step order
  text         String  // step instruction
  duration     Int?    // seconds (optional)
  techniqueTag String? // e.g., "sauté", "bake", "rest"

  @@index([recipeId])
}

// DeviceToken model - push notification registration
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  platform  Platform

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Bookmark model - user's saved recipes
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
  @@index([recipeId])
}

// CityLocation model - geocoding cache to minimize Mapbox API calls
model CityLocation {
  id        String   @id @default(cuid())
  cityName  String   @unique
  latitude  Float
  longitude Float
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// VoiceProfile model - user's cloned voice for narration
model VoiceProfile {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  status             VoiceStatus @default(PENDING)
  elevenLabsVoiceId  String?     // populated after cloning completes
  audioSampleUrl     String      // R2 URL for voice sample backup

  speakerName        String      // e.g., "Mom", "Nonna Maria"
  relationship       String      // e.g., "Mother", "Grandmother"

  consentedAt        DateTime?   // legal compliance timestamp
  consentIpAddress   String?     // IP when consent given
  consentAppVersion  String?     // App version when consent was given (for audit trail)

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([userId, status])
}

// NarrationScript model - cache for Gemini conversational rewriting
model NarrationScript {
  id                 String   @id @default(cuid())
  recipeId           String   @unique // one cached narration per recipe (voice-independent)
  conversationalText String   // Gemini-rewritten narration text
  generatedAt        DateTime @default(now())

  @@index([recipeId])
}

// Subscription model - StoreKit 2 subscription tracking
model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  productId             String
  transactionId         String
  originalTransactionId String
  expiresDate           DateTime
  isActive              Boolean  @default(true)
  jwsPayload            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

// PantryItem model - user's pantry inventory
model PantryItem {
  id              String   @id @default(cuid())
  userId          String
  name            String
  normalizedName  String?
  quantity        String
  unit            String?
  storageLocation String   // "fridge" | "freezer" | "pantry"
  foodCategory    String?  // "dairy" | "produce" | "meat" | "seafood" | "grains" | "baking" | "spices" | "beverages" | "snacks" | "condiments"
  photoUrl        String?
  notes           String?
  source          String   @default("manual")  // "manual" | "fridge_scan" | "receipt_scan"
  expiryDate      DateTime?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDeleted])
  @@index([normalizedName])
  @@index([expiryDate])
}

// IngredientCatalog model - bilingual ingredient normalization
model IngredientCatalog {
  id                   String   @id @default(cuid())
  canonicalName        String   @unique
  canonicalNameTR      String
  aliases              String[]
  defaultCategory      String
  defaultShelfLifeDays Int?
  createdAt            DateTime @default(now())

  @@index([canonicalName])
  @@index([canonicalNameTR])
}

// ScanJob model - AI scan result persistence
model ScanJob {
  id        String   @id @default(cuid())
  userId    String
  scanType  String   // "FRIDGE" | "RECEIPT"
  photoUrl  String?  // R2 URL for fridge scans
  ocrText   String?  // Raw OCR text for receipt scans (intermediate, useful for debugging)
  status    String   @default("PROCESSING")  // UPLOADING | PROCESSING | COMPLETED | FAILED
  results   Json?    // DetectedItem[] JSON array
  error     String?  // Error message if failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentHash String?  // SHA-256 hash for deduplication

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, scanType])
  @@index([userId, contentHash])
}

// NarrationAudio model - cached TTS audio in R2 to avoid redundant ElevenLabs calls
model NarrationAudio {
  id             String   @id @default(cuid())
  recipeId       String
  voiceProfileId String
  r2Url          String
  sizeBytes      Int
  durationMs     Int?     // MP3 duration in milliseconds, computed at upload time
  createdAt      DateTime @default(now())

  @@unique([recipeId, voiceProfileId])
  @@index([recipeId])
}

// TransactionHistory model - audit trail for StoreKit transactions and App Store Server Notifications
model TransactionHistory {
  id                    String   @id @default(cuid())
  userId                String?
  transactionId         String?
  originalTransactionId String?
  productId             String?
  jwsPayload            String
  environment           String   // "PRODUCTION" | "SANDBOX"
  verificationResult    String   // "SUCCESS" | "FAILURE"
  errorMessage          String?
  expiresDate           DateTime?
  notificationType      String?  // For App Store Server Notifications V2
  receivedAt            DateTime @default(now())

  @@index([userId])
  @@index([transactionId])
  @@index([environment])
}

// NotificationPreferences model - per-category push notification opt-out
model NotificationPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  expiryAlerts  Boolean  @default(true)
  voiceReady    Boolean  @default(true)
  engagement    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// NotificationLog model - tracking for engagement notification rate limiting (max 3/week)
model NotificationLog {
  id     String   @id @default(cuid())
  userId String
  type   String   // "EXPIRY" | "VOICE_READY" | "ENGAGEMENT"
  sentAt DateTime @default(now())

  @@index([userId, type, sentAt])
}

// SearchCache model - cache search results to reduce Spoonacular API calls
model SearchCache {
  id            String   @id @default(cuid())
  normalizedKey String   @unique // normalized query params hash
  recipeIds     String[] // array of recipe IDs from search
  cachedAt      DateTime @default(now())

  @@index([cachedAt])
}

// ApiQuotaUsage model - track daily Spoonacular API quota consumption
model ApiQuotaUsage {
  id         String   @id @default(cuid())
  date       String   @unique // YYYY-MM-DD
  pointsUsed Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
}

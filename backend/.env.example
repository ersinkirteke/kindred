# Database
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev: postgresql://kindred:kindred_dev@localhost:5432/kindred
# Production: Get from your hosting provider
DATABASE_URL=

# Server
# Environment: development | staging | production
NODE_ENV=development
# Port for the NestJS app to listen on
PORT=3000

# Authentication (Clerk)
# Get from: https://dashboard.clerk.com/ -> API Keys
# Secret key for server-side Clerk SDK
CLERK_SECRET_KEY=
# Publishable key for client-side SDKs (iOS/Android)
CLERK_PUBLISHABLE_KEY=

# Cloudflare R2 Storage
# Get from: Cloudflare Dashboard -> R2 -> Manage R2 API Tokens
# Access key ID for R2 (S3-compatible)
R2_ACCESS_KEY_ID=
# Secret access key for R2
R2_SECRET_ACCESS_KEY=
# Your Cloudflare account ID (found in dashboard URL)
CLOUDFLARE_ACCOUNT_ID=
# R2 bucket name for image storage (create via Cloudflare Dashboard -> R2 -> Create Bucket)
R2_BUCKET_NAME=kindred-images
# Public CDN URL for R2 bucket (custom domain or r2.dev subdomain from bucket settings)
R2_PUBLIC_URL=https://images.kindred.app

# Google Cloud AI Services
# Get from: https://console.cloud.google.com/
# Project ID for Google Cloud services (Imagen 4, Gemini)
GOOGLE_CLOUD_PROJECT=
# Path to Google Cloud service account JSON file for Imagen API authentication
# Generate at: Google Cloud Console -> IAM & Admin -> Service Accounts -> Create Key (JSON)
# NOTE: This is used by @google-cloud/aiplatform SDK (reads from GOOGLE_APPLICATION_CREDENTIALS)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Path to Firebase service account JSON file for push notifications and AI services
# Generate at: Firebase Console -> Project Settings -> Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=
# Google AI API Key for Gemini (recipe parsing)
# Get from: Google AI Studio -> Get API Key or Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_AI_API_KEY=

# X API (Recipe Scraping)
# Get from: developer.x.com -> Projects & Apps -> Keys and Tokens -> Bearer Token
# Requires Basic tier ($200/month) for search endpoint access
X_API_BEARER_TOKEN=

# Scraping Configuration
# Comma-separated list of target cities for recipe discovery
# Default: New York,Los Angeles,Chicago,Houston,Phoenix
SCRAPING_TARGET_CITIES=New York,Los Angeles,Chicago,Houston,Phoenix

# Mapbox Geocoding
# Get from: https://account.mapbox.com/access-tokens/
# Used for: City name -> lat/lng conversion, GPS -> city name, city search autocomplete
MAPBOX_ACCESS_TOKEN=

# ElevenLabs Voice Cloning
# Get from: https://elevenlabs.io/app/settings/api-keys
# Used for: Voice cloning and text-to-speech narration
ELEVENLABS_API_KEY=

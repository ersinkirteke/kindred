# Fastlane configuration for Kindred iOS app
# Note: This project uses XcodeGen (project.yml), so build number increments
# are managed via the generated .xcodeproj file, not project.yml.
# The CURRENT_PROJECT_VERSION in project.yml is separate from fastlane's runtime build numbering.

default_platform(:ios)

platform :ios do
  before_all do
    # Verify we're in the correct directory
    ensure_git_status_clean unless ENV["SKIP_GIT_STATUS_CHECK"]

    # Change to Kindred directory where Xcode project is located
    Dir.chdir("..") do
      unless File.exist?("Kindred.xcodeproj")
        UI.user_error!("Kindred.xcodeproj not found. Run from fastlane directory.")
      end
    end
  end

  desc "Pre-flight checks before any upload (fail fast on config errors)"
  lane :precheck do
    # Check 1: Release.xcconfig placeholders
    xcconfig_path = File.join("..", "Config", "Release.xcconfig")
    xcconfig_content = File.read(xcconfig_path)
    if xcconfig_content.include?("REPLACE_WITH_")
      UI.user_error!("❌ Release.xcconfig contains REPLACE_WITH_ placeholder values — fix before release")
    end
    UI.success("✅ Release.xcconfig: no REPLACE_WITH_ placeholders")

    # Check 2: .env file completeness
    env_path = File.join(Dir.pwd, ".env")
    unless File.exist?(env_path)
      UI.user_error!("❌ fastlane/.env file not found — copy from .env.default and populate values")
    end

    env_content = File.read(env_path)
    required_keys = ["APP_STORE_CONNECT_API_KEY_ID", "APP_STORE_CONNECT_ISSUER_ID", "APP_STORE_CONNECT_API_KEY_FILEPATH"]
    required_keys.each do |key|
      unless env_content.include?("#{key}=") && env_content[/#{key}=(.+)/, 1].to_s.strip.length > 0
        UI.user_error!("❌ fastlane/.env missing required key: #{key}")
      end
    end
    UI.success("✅ .env: all required App Store Connect API keys present")

    # Check 3: .p8 API key file readable
    p8_path = ENV["APP_STORE_CONNECT_API_KEY_FILEPATH"]
    unless p8_path && File.exist?(p8_path) && File.readable?(p8_path)
      UI.user_error!("❌ .p8 API key file not readable at #{p8_path} — regenerate from App Store Connect → Users & Access → Integrations → API Keys")
    end
    UI.success("✅ .p8 API key: readable at #{p8_path}")

    # Check 4: Metadata files exist and non-empty in both locales
    locales = %w[en-US tr]
    metadata_files = %w[name.txt subtitle.txt description.txt keywords.txt promotional_text.txt release_notes.txt support_url.txt privacy_url.txt marketing_url.txt]
    optional_empty_files = %w[marketing_url.txt]  # Files that can be empty (marketing site not yet launched)

    locales.each do |locale|
      metadata_files.each do |file|
        file_path = File.join(Dir.pwd, "metadata", locale, file)
        unless File.exist?(file_path)
          UI.user_error!("❌ Missing metadata file: metadata/#{locale}/#{file}")
        end
        # Allow optional files to be empty
        if File.size(file_path) == 0 && !optional_empty_files.include?(file)
          UI.user_error!("❌ Empty metadata file: metadata/#{locale}/#{file}")
        end
      end
    end
    UI.success("✅ Metadata: all 9 required files present (marketing_url.txt may be empty) in en-US and tr")

    # Check 5: Screenshots (exactly 5 per locale)
    locales.each do |locale|
      screenshots = Dir.glob(File.join(Dir.pwd, "screenshots", locale, "*.png"))
      count = screenshots.length
      unless count == 5
        UI.user_error!("❌ Expected 5 screenshots in screenshots/#{locale}/, found #{count}")
      end
    end
    UI.success("✅ Screenshots: 5 PNGs present in en-US and tr")

    # Check 6: Sanity recap
    UI.success("🎉 All pre-flight checks passed — safe to proceed with build")
  end

  desc "Build and distribute internal TestFlight beta"
  lane :beta_internal do
    precheck

    # Increment build number based on git commits for reproducibility
    build_num = number_of_commits.to_i
    project_dir = File.expand_path("..", Dir.pwd)
    sh("cd '#{project_dir}' && agvtool new-version -all #{build_num}")

    # Build the app
    project_dir = File.expand_path("..", Dir.pwd)
    build_app(
      project: File.join(project_dir, "Kindred.xcodeproj"),
      scheme: "Kindred",
      configuration: "Release",
      export_method: "app-store"
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      groups: ["Internal Testers"]
    )

    UI.success("Internal beta build uploaded successfully!")
  end

  desc "Build and distribute external TestFlight beta"
  lane :beta_external do
    # Increment build number based on git commits for reproducibility
    build_num = number_of_commits.to_i
    project_dir = File.expand_path("..", Dir.pwd)
    sh("cd '#{project_dir}' && agvtool new-version -all #{build_num}")

    # Build the app
    project_dir = File.expand_path("..", Dir.pwd)
    build_app(
      project: File.join(project_dir, "Kindred.xcodeproj"),
      scheme: "Kindred",
      configuration: "Release",
      export_method: "app-store"
    )

    # Upload to TestFlight with beta review info
    upload_to_testflight(
      distribute_external: true,
      groups: ["External Testers"],
      changelog: "Welcome to the Kindred beta! This is the initial beta release.\n\nKey features:\n• Voice narration with AI-cloned voices (powered by ElevenLabs)\n• Trending local recipes from your city\n• Smart pantry scanning\n• Dietary personalization\n\nWe'd love your feedback as we prepare for the App Store launch!",
      beta_app_review_info: {
        contact_email: ENV["BETA_CONTACT_EMAIL"] || "support@kindred.app",
        contact_first_name: "Ersin",
        contact_last_name: "Kirteke",
        contact_phone: ENV["BETA_CONTACT_PHONE"] || "+1-555-000-0000",
        demo_account_required: true,
        demo_account_name: ENV["BETA_DEMO_EMAIL"] || "beta@kindred.app",
        demo_account_password: ENV["BETA_DEMO_PASSWORD"] || "demo123",
        notes: "IMPORTANT: This app uses ElevenLabs AI voice cloning technology.\n\n" \
               "Voice profiles require explicit user consent before upload. " \
               "Users can delete voice profiles from Settings at any time.\n\n" \
               "Demo account: Login with the provided credentials above. " \
               "Voice narration requires internet connection and ElevenLabs API access."
      }
    )

    UI.success("External beta build uploaded successfully!")
  end

  desc "Build and submit to App Store"
  lane :release do
    precheck

    # Increment build number based on git commits for reproducibility
    build_num = number_of_commits.to_i
    project_dir = File.expand_path("..", Dir.pwd)
    sh("cd '#{project_dir}' && agvtool new-version -all #{build_num}")

    # Build the app
    project_dir = File.expand_path("..", Dir.pwd)
    build_app(
      project: File.join(project_dir, "Kindred.xcodeproj"),
      scheme: "Kindred",
      configuration: "Release",
      export_method: "app-store"
    )

    # Upload to App Store Connect and submit for review
    upload_to_app_store(
      submit_for_review: true,
      automatic_release: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_encryption_updated: false,
        export_compliance_is_exempt: true
      }
    )

    UI.success("App submitted to App Store successfully!")
  end
end

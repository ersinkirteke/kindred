	<key>GADApplicationIdentifier</key>
	<string>$(ADMOB_APP_ID)</string>
	<key>ADMOB_FEED_NATIVE_ID</key>
	<string>$(ADMOB_FEED_NATIVE_ID)</string>
	<key>ADMOB_DETAIL_BANNER_ID</key>
	<string>$(ADMOB_DETAIL_BANNER_ID)</string>
